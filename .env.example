# RAG-Quest Configuration (v0.5.2)
# Copy this to .env and fill in your settings
# Or use environment variables directly

# ============================================================================
# LLM Provider Configuration
# ============================================================================

# Provider: ollama (recommended), openai, or openrouter
LLM_PROVIDER=ollama

# Ollama Settings (if provider=ollama)
OLLAMA_MODEL=gemma4:e4b
OLLAMA_BASE_URL=http://localhost:11434

# OpenAI Settings (if provider=openai)
# Get key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-3.5-turbo

# OpenRouter Settings (if provider=openrouter)
# Get key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=mistralai/mistral-7b-instruct

# ============================================================================
# RAG Configuration
# ============================================================================

# RAG Profile: fast (speed), balanced (recommended), or deep (quality)
RAG_PROFILE=balanced

# ============================================================================
# Game Configuration
# ============================================================================

# World name (used for save/RAG directory)
WORLD_NAME=

# Character name (created if not present)
CHARACTER_NAME=

# World setting/tone (optional)
WORLD_SETTING=
WORLD_TONE=

# Auto-save interval (turns)
AUTO_SAVE_INTERVAL=5

# ============================================================================
# Advanced Settings
# ============================================================================

# Debug mode (set to true for verbose output)
DEBUG=false

# TTS Provider: pyttsx3 (offline) or gtts (online)
TTS_PROVIDER=pyttsx3

# Notes:
# - All settings can be set via environment variables OR .env file
# - Environment variables take precedence over .env file
# - Ollama is recommended for local, private play
# - Gemma 4 E4B (4B) is recommended for GPU systems
# - Gemma 4 E2B (2B) is recommended for CPU-only systems
# - RAG profiles: fast (weak hardware), balanced (typical), deep (high-end)
