# RAG-Quest Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# LLM Provider (required)
# ============================================
# Choose: ollama, openai, or openrouter

LLM_PROVIDER=ollama

# ============================================
# Ollama Configuration (Local - Recommended)
# ============================================
# For local AI inference without API keys
# Recommended: Gemma 4 (fast, open-source)
#   - gemma4 or gemma4:latest (auto-selects best available)
#   - gemma4-e2b (2B model - CPU only, slow but works everywhere)
#   - gemma4-e4b (4B model - GPU recommended, best quality)

OLLAMA_MODEL=gemma4
OLLAMA_BASE_URL=http://localhost:11434

# ============================================
# OpenAI Configuration
# ============================================
# For OpenAI GPT models
# Requires: OPENAI_API_KEY from https://platform.openai.com/api-keys

# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# ============================================
# OpenRouter Configuration
# ============================================
# For multi-model cloud provider
# Requires: OPENROUTER_API_KEY from https://openrouter.ai/

# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=anthropic/claude-sonnet-4

# ============================================
# RAG Configuration (LightRAG Profiles)
# ============================================
# Profile affects chunk size, query mode, and token limits
# Speed/quality tradeoff

RAG_PROFILE=balanced

# Options:
# - fast     : Larger chunks, naive queries, best for old/slow hardware
# - balanced : Moderate chunks, local queries, good default
# - deep     : Tiny chunks, hybrid queries, best immersion on capable hardware

# ============================================
# TTS (Text-to-Speech) Configuration
# ============================================
# Have the narrator read responses aloud

TTS_ENABLED=false

# TTS_ENGINE=pyttsx3            # Options: pyttsx3 (offline), gtts (online)
# TTS_VOICE=david               # Voice selection (depends on engine)
# TTS_RATE=150                  # Speech rate (words per minute)
# TTS_VOLUME=0.9                # Volume (0.0-1.0)

# ============================================
# Save System Configuration (v0.5+)
# ============================================
# Game persistence and backup

# SAVE_DIR=~/.local/share/rag-quest/saves
# AUTO_SAVE_INTERVAL=3  # Auto-save every N actions
# AUTO_SAVE_SLOTS=3     # Keep N rotating auto-saves
# MAX_SAVE_SLOTS=5      # Maximum manual save slots per world

# ============================================
# Multiplayer Configuration (v0.5+)
# ============================================
# Local hot-seat multiplayer

# MULTIPLAYER_ENABLED=true      # Enable/disable multiplayer
# MULTIPLAYER_MAX_PLAYERS=4     # Max concurrent players
# TRADING_ENABLED=true          # Allow item trading

# ============================================
# Achievements & Dungeons (v0.5+)
# ============================================
# Game features

# ACHIEVEMENTS_ENABLED=true     # Enable achievement tracking
# DUNGEON_ENABLED=true          # Enable procedural dungeons
# DUNGEON_MIN_ROOMS=5           # Minimum rooms per level
# DUNGEON_MAX_ROOMS=15          # Maximum rooms per level

# ============================================
# Game Configuration
# ============================================
# Gameplay settings

# GAME_LOG_LEVEL=INFO                    # DEBUG, INFO, WARNING, ERROR
# MAX_PARTY_SIZE=4                       # Maximum party members
# NPC_COMPANION_AI=true                  # Enable companion AI
# WORLD_EVENTS_ENABLED=true              # Enable dynamic events
