# RAG-Quest Environment Configuration

# LLM Provider Configuration
# Uncomment and fill in the provider you want to use

# ============================================
# OpenAI Configuration
# ============================================
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# ============================================
# OpenRouter Configuration
# ============================================
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=anthropic/claude-sonnet-4

# ============================================
# Ollama Configuration (Local - Recommended)
# ============================================
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=gemma4-e2b     # For CPU (2B, fast)
# OLLAMA_MODEL=gemma4-e4b     # For GPU (4B, best quality)

# ============================================
# RAG Configuration (LightRAG Profiles)
# ============================================
# RAG_PROFILE=balanced  # Options: fast, balanced, deep
#
# fast     - Larger chunks, naive queries, best for weak hardware
# balanced - Moderate chunks, local queries, good default
# deep     - Small chunks, hybrid queries, best for immersion & capable hardware

# ============================================
# TTS (Text-to-Speech) Configuration
# ============================================
# TTS_ENABLED=true              # Enable/disable TTS narration
# TTS_ENGINE=pyttsx3            # Options: pyttsx3 (offline), gtts (online)
# TTS_VOICE=david               # Voice selection (depends on engine)
# TTS_RATE=150                  # Speech rate (words per minute)
# TTS_VOLUME=0.9                # Volume (0.0-1.0)

# ============================================
# Save System Configuration (v0.5+)
# ============================================
# SAVE_DIR=~/.local/share/rag-quest/saves
# AUTO_SAVE_INTERVAL=5  # Auto-save every N actions (0 to disable)
# AUTO_SAVE_SLOTS=3  # Number of auto-save rotations to keep
# MAX_SAVE_SLOTS=5  # Maximum manual save slots per world

# ============================================
# Multiplayer Configuration (v0.5+)
# ============================================
# MULTIPLAYER_ENABLED=true  # Enable local multiplayer mode
# MULTIPLAYER_MAX_PLAYERS=4  # Maximum players in multiplayer session
# TRADING_ENABLED=true  # Enable item trading between players

# ============================================
# Achievements & Dungeons (v0.5+)
# ============================================
# ACHIEVEMENTS_ENABLED=true  # Enable achievement tracking
# DUNGEON_ENABLED=true  # Enable procedural dungeons
# DUNGEON_MIN_ROOMS=5  # Minimum rooms per dungeon level
# DUNGEON_MAX_ROOMS=15  # Maximum rooms per dungeon level

# ============================================
# Game Configuration
# ============================================
# GAME_LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR
# MAX_PARTY_SIZE=4  # Maximum party members (including player)
# NPC_COMPANION_AI=true  # Enable companion AI behavior
# WORLD_EVENTS_ENABLED=true  # Enable dynamic world events
